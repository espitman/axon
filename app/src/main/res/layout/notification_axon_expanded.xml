<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/axon_notification_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/notification_axon_bg"
    android:orientation="vertical"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/notification_axon_panel"
        android:orientation="vertical"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <FrameLayout
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/notification_axon_mark_bg"
                android:padding="8dp">

                <ImageView
                    android:id="@+id/axon_notification_icon"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@string/app_name"
                    android:src="@drawable/ic_axon_mark" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/axon_notification_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:fontFamily="@font/vazirmatn_bold"
                    android:maxLines="1"
                    android:textColor="#F4F7F5"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/axon_notification_origin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:ellipsize="end"
                    android:fontFamily="@font/vazirmatn_regular"
                    android:maxLines="1"
                    android:textColor="#31D7D5"
                    android:textSize="11sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/axon_notification_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:background="@drawable/notification_axon_badge"
                android:fontFamily="@font/vazirmatn_bold"
                android:gravity="center"
                android:maxLines="1"
                android:textColor="#31D7D5"
                android:textSize="10sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/axon_notification_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:ellipsize="end"
            android:fontFamily="@font/vazirmatn_regular"
            android:maxLines="3"
            android:textColor="#F4F7F5"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/axon_notification_reject"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/notification_axon_reject"
            android:fontFamily="@font/vazirmatn_bold"
            android:gravity="center"
            android:maxLines="1"
            android:text="Reject"
            android:textColor="#210707"
            android:textSize="14sp"
            android:visibility="gone" />
    </LinearLayout>
</LinearLayout>
