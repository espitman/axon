<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/axon_notification_root"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:background="@drawable/notification_axon_bg"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="12dp"
    android:paddingTop="8dp"
    android:paddingEnd="12dp"
    android:paddingBottom="8dp">

    <FrameLayout
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:background="@drawable/notification_axon_mark_bg"
        android:padding="8dp">

        <ImageView
            android:id="@+id/axon_notification_icon"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@string/app_name"
            android:src="@drawable/ic_axon_mark" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/axon_notification_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:fontFamily="@font/vazirmatn_bold"
            android:maxLines="1"
            android:textColor="#F4F7F5"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/axon_notification_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:ellipsize="end"
            android:fontFamily="@font/vazirmatn_regular"
            android:maxLines="1"
            android:textColor="#A4B0AD"
            android:textSize="12sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/axon_notification_badge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:background="@drawable/notification_axon_badge"
        android:fontFamily="@font/vazirmatn_bold"
        android:gravity="center"
        android:maxLines="1"
        android:textColor="#31D7D5"
        android:textSize="10sp" />
</LinearLayout>
